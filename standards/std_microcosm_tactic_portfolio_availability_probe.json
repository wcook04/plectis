    "formal_proof_authority": false,
    "provider_calls_authorized": false,
    "benchmark_performance_authority": false,
    "release_authorized": false
  },
  "standard_payload": {
    "ontology": "A public tactic availability probe made from copied macro rows plus copied Lean probe source bodies, with digest coupling and explicit no-proof-authority boundaries.",
    "teleology": "Let a cold reader inspect the actual public-safe Lean source that produced the tactic availability rows before relying on the normalized portfolio projection.",
    "anti_purpose": "Treating availability rows, copied tactic probes, or Mathlib absence as theorem proof authority, benchmark performance, or release authority.",
    "compression_bands": [
      "copied_probe_sources",
      "availability_rows",
      "mathlib_absence_boundary",
      "consumer_tactic_gating",
      "negative_cases",
      "authority_ceiling"
    ],
    "failure_modes": [
      "copied Lean probe source artifact missing from public bundle",
      "copied Lean probe source artifact digest differs from macro source",
      "tactic row omits compile status",
      "Mathlib-dependent tactic marked available without a passing Mathlib probe",
      "consumer references a tactic absent from the declared portfolio",
      "private theorem proof body or provider payload appears in public output",
      "availability row upgraded into theorem proof or benchmark authority",
      "release or provider-call authority implied by an environment-scoped probe"
    ],
    "rebuild_action": "validate tactic portfolio fixture, exported bundle, and workingness map"
  },
  "anti_claim": "Tactic portfolio availability is an environment-scoped probe artifact; it does not prove theorem correctness, authorize provider output, claim benchmark performance, or authorize release."
