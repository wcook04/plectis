  "validation_rules": [
    "Each tactic row declares compile_status in a scoped pass/fail vocabulary.",
    "Mathlib-dependent tactics cannot be marked available unless the Mathlib import probe passed.",
    "Consumers cannot reference tactics absent from the declared portfolio probe.",
    "Copied Lean probe source bodies must be present and match declared source digests.",
    "Private theorem proof bodies, raw provider payloads, benchmark claims, release authority, and private paths are rejected."
  ],
