  },
  "receipt_contract": {
    "status_field": "status",
    "body_material_status": "copied_non_secret_macro_body_with_provenance",
    "tactic_availability_status": "real_lean_std_tactic_affordance_probe_rows",
    "probe_source_body_status": "copied_non_secret_lean_probe_source_bodies_with_digest_verification",
    "source_artifact_count": 10,
    "source_artifact_digest_verification_required": true,
    "secret_exclusion_scan_required": true,
    "required_negative_cases": [
      "missing_compile_status",
      "mathlib_claim_without_probe",
      "unprobed_tactic_referenced",
      "proof_body_leakage",
      "authority_overclaim"
    ]
  },
  "public_private_boundary": {
    "public_inputs": "copied non-secret Lean/Std tactic affordance rows, copied Lean probe source bodies, scoped Mathlib absence probe result, and corpus readiness boundary refs from the 2026-05-11 smoke run",
    "private_inputs_forbidden": [
      "private theorem proof bodies",
      "provider payloads",
      "private source paths",
      "live benchmark claims"
    ],
    "release_authorized": false
  },
  "authority_ceiling": {
    "status": "pass",
