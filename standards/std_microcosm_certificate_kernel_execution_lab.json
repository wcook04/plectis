  "standard_payload": {
    "ontology": "A public certificate-kernel execution lab that carries Lean/Lake tool-witness metadata, analyzer receipts, typed CP2 action translation, bounded Evolve policy reruns, negative cases, and authority ceilings without exporting proof, provider, oracle, private-source, stdout, stderr, credential, or account-bound payload bodies.",
