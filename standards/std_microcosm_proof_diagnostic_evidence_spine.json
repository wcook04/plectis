    "authority_ceiling",
    "anti_claim"
  ],
  "validation_rules": [
    "Every copied Ring2 diagnostic artifact must exist under the exported evidence bundle.",
    "Every copied Ring2 diagnostic artifact sha256 must match the macro source digest.",
    "Provider-advisory rows must remain metadata and must not become proof authority.",
    "Proof bodies, provider payload bodies, oracle-needed proof text, account/session state, cookies, browser/HUD live-access payloads, and credential-equivalent material are forbidden.",
    "Diagnostic-board source-authority upgrades are rejected.",
    "Passing diagnostic checks cannot claim runtime correctness or theorem correctness.",
    "Stale source coupling is retained as diagnostic evidence instead of hidden.",
    "Formal prover execution remains unauthorized in this organ."
  ],
  "receipt_expectations": [
    "proof_receipts.json with accepted/rejected diagnostic receipt rows",
    "provider_payload_policy_result.json with proof-body/provider-body rejection status",
    "diagnostic_board.json with weak-edge retention and authority ceiling",
    "proof_evidence_validation_receipt.json with negative-case coverage and copied-artifact digest status",
    "exported_evidence_bundle_validation_result.json with copied macro body artifact count and digest verification"
  ],
  "validator_contract": {
    "required": true,
    "validator_id": "validator.microcosm.organs.proof_diagnostic_evidence_spine",
    "module": "microcosm_core.organs.proof_diagnostic_evidence_spine",
    "actions": [
      "run",
      "run-evidence-bundle"
    ],
    "minimum_checks": [
      "negative_case_coverage",
      "secret_exclusion_scan",
      "copied_macro_body_digest_verification",
      "provider_payload_boundary",
      "diagnostic_board_authority_ceiling",
      "runtime_correctness_overclaim_rejection",
      "stale_source_coupling_retention"
    ],
    "negative_case_count": 5
  },
  "receipt_contract": {
    "required": true,
    "receipt_id": "receipt.microcosm.proof_diagnostic_evidence_spine",
    "must_record": [
      "validator_id",
      "accepted_check_ids",
      "rejected_check_ids",
      "observed_negative_cases",
      "missing_negative_cases",
      "copied_macro_body_artifacts",
      "copied_macro_body_digest_status",
      "source_digest_sha256_by_ref",
      "source_target_refs",
      "authority_ceiling",
      "anti_claim",
      "secret_exclusion_scan"
    ]
  },
  "public_private_boundary": {
    "default_posture": "public_safe_when_ring2_runtime_artifacts_are_digest_verified_and_forbidden_bodies_are_absent",
    "allowed_public_inputs": [
      "Ring2 diagnostic run summaries",
      "Ring2 failure taxonomy metadata",
      "Ring2 graph-update candidate metadata",
      "formal evidence-cell receipt refs",
      "verifier-trace repair receipt refs",
      "diagnostic check ids and validator metadata",
      "provider-advisory receipt refs without payload bodies"
    ],
    "forbidden_public_inputs": [
      "proof bodies",
      "oracle-needed proof text",
      "provider payload bodies",
      "credentials",
      "account or browser session state",
      "cookies",
      "browser/HUD live-access payloads",
      "recipient-send state",
      "private personal material"
    ]
  },
  "authority_ceiling": {
    "status": "pass",
    "standard_authority": "proof_diagnostic_runtime_artifact_schema_and_digest_contract",
    "formal_proof_authority": false,
    "lean_lake_execution_authorized": false,
    "provider_calls_authorized": false,
    "runtime_correctness_claim": false,
    "release_authorized": false,
    "publication_authorized": false,
    "recipient_send_authorized": false
  },
  "anti_claim": "This standard governs copied Ring2 diagnostic runtime artifacts and proof-adjacent receipt refs only; it does not certify theorem correctness, proof authority, provider output, Lean/Lake execution, release readiness, publication, or private macro equivalence.",
  "standard_payload": {
    "ontology": "A public-safe proof-diagnostic spine that carries Ring2 diagnostic runtime artifacts, receipt anchors, negative-case policy checks, and source digest coupling before any formal proof authority.",
    "teleology": "Replace pointer-only proof-diagnostic evidence with copied non-secret runtime artifacts and a bounded failure envelope a cold reader can validate.",
    "anti_purpose": "Treating diagnostic metadata, provider advisory rows, or copied Ring2 run artifacts as theorem proof authority.",
    "compression_bands": [
      "ring2_runtime_artifacts",
      "diagnostic_receipt_refs",
      "provider_boundary",
      "negative_cases",
      "authority_ceiling",
      "digest_coupling"
    ],
    "failure_modes": [
      "copied Ring2 artifact missing from public bundle",
      "copied Ring2 artifact digest does not match macro source digest",
      "provider advisory metadata upgraded into proof authority",
      "proof body or provider payload body appears in public output",
      "diagnostic board claims source authority",
      "passing diagnostic check claims runtime or theorem correctness",
      "stale source coupling hidden instead of retained as diagnostic evidence",
      "formal prover execution implied before the proof witness organ"
    ],
    "rebuild_action": "validate exported proof diagnostic bundle and workingness map"
  },
  "receipt_refs": [
    "receipts/first_wave/proof_diagnostic_evidence_spine/proof_receipts.json",
    "receipts/first_wave/proof_diagnostic_evidence_spine/provider_payload_policy_result.json",
    "receipts/first_wave/proof_diagnostic_evidence_spine/diagnostic_board.json",
    "receipts/first_wave/proof_diagnostic_evidence_spine/proof_evidence_validation_receipt.json",
    "receipts/runtime_shell/demo_project/organs/proof_diagnostic_evidence_spine/exported_evidence_bundle_validation_result.json"
  ],
  "validator_refs": [
    "microcosm_core.organs.proof_diagnostic_evidence_spine"
  ],
  "paper_module_contract": {
    "required": true,
    "module_slug": "proof_diagnostic_evidence_spine"
  },
  "anti_claim_contract": {
    "required": true,
    "rule": "Proof-diagnostic material must state that diagnostics are not proof authority."
  },
  "source_coupling_contract": {
    "required": true,
    "rule": "Copied Ring2 artifacts must remain byte-digest coupled to macro source refs and public-root relative targets."
  }
}
