    "checks[].check_id",
    "checks[].validator_id",
    "checks[].expected_result",
    "checks[].source_refs",
    "checks[].source_digest_refs",
    "diagnostic_rows[].diagnostic_id",
    "diagnostic_rows[].receipt_anchor_refs",
