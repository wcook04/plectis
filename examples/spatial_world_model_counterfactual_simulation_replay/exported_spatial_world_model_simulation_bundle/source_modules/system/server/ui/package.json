{
  "name": "ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cd ../../.. && ./repo-python tools/meta/testing/frontend_dev_server.py",
    "dev:all": "cd ../../.. && ./repo-python tools/meta/testing/frontend_dev_server.py --dev-all",
    "dev:vite-only": "cd ../../.. && ./repo-python tools/meta/testing/frontend_dev_server.py",
    "typecheck": "tsc -p tsconfig.app.json --incremental && tsc -p tsconfig.node.json --incremental",
    "build": "npm run check:station-geometry && npm run typecheck && vite build",
    "build:web": "npm run check:station-geometry && npm run typecheck && vite build",
    "build:embedded": "npm run typecheck && ZENITH_UI_BASE=./ ZENITH_UI_OUTDIR=../../../apps/zenith-macos/dist/ZenithApp.app/Contents/Resources/EmbeddedWeb vite build",
    "build:embedded:installed": "npm run typecheck && ZENITH_UI_BASE=./ ZENITH_UI_OUTDIR=/Applications/Zenith.app/Contents/Resources/EmbeddedWeb vite build",
    "build:all": "npm run build:web && npm run build:embedded && npm run build:embedded:installed",
    "test": "cd ../../.. && ./repo-python tools/meta/testing/frontend_vitest.py",
    "lint": "eslint .",
    "preview": "vite preview",
    "check:station-geometry": "cd ../../.. && ./repo-python tools/meta/factory/check_station_geometry.py --check",
    "generate:api-types": "cd ../../.. && ./repo-python tools/meta/factory/build_api_type_projection.py",
    "check:api-types": "cd ../../.. && ./repo-python tools/meta/factory/build_api_type_projection.py --check",
    "bisect:api-aliases": "cd ../../.. && ./repo-python tools/meta/factory/build_api_alias_projection.py --bisect-aliases"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "framer-motion": "^12.29.3",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "reactflow": "^11.11.4",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dagre": "^0.7.53",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^3.2.4"
  }
}
