    },
    "prover_strategy_classification": {
      "label": "Prover strategy classification (provider chooses one mathematical_strategy_atlas_v0 strategy_id; advisory only)",
      "low_authority_allowed": true,
      "required_authority_tier": "provider_endpoint",
      "input_packet": [
        "prover_context_pack",
        "retrieval_report_ref",
        "skill_decision_ref",
        "provider_task",
        "allowed_premise_ids",
        "output_schema"
      ],
      "output_schema": {
        "type": "object",
        "required": [
          "strategy_id",
          "confidence",
          "reasons",
          "decomposition_hint",
          "forbidden_output_audit",
          "omissions"
        ],
        "properties": {
          "strategy_id": {
            "type": "string",
            "enum": [
              "equality_normal_form",
              "iff_split",
              "constructor_injectivity",
              "recursive_data_induction",
              "membership_decomposition",
              "composition_fusion",
              "symmetry_or_orientation",
              "contradiction_or_false_target"
            ]
          },
          "confidence": {
            "type": "number"
          },
          "reasons": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "decomposition_hint": {
            "type": "string"
          },
          "expected_tactic_family": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expected_premise_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "forbidden_output_audit": {
            "type": "object",
            "required": [
              "contains_lean_proof_body",
              "contains_full_tactic_script",
              "contains_oracle_material"
            ],
            "properties": {
              "contains_lean_proof_body": {
                "type": "boolean"
              },
              "contains_full_tactic_script": {
                "type": "boolean"
              },
              "contains_oracle_material": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          },
          "omissions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      },
      "validation_command": "./repo-python tools/meta/factory/run_prover_graph_benchmark.py --provider-context-sweep --check --json",
      "forbidden_surfaces": [
        "oracle_only_repair_bodies",
        "truth_side_proof_bodies",
        "test_split_truth",
        "source_writes"
      ],
      "authority_note": "Provider workers classify the target into exactly one mathematical_strategy_atlas_v0 strategy_id and emit bounded advisory metadata. Provider output is never proof authority; deterministic search consumption + downstream evaluator deltas remain Type A controller work. Mechanical prevention: output_schema enumerates strategy_id (8 known values), uses additionalProperties=false, and excludes proof/tactic/oracle output fields, so the provider cannot return forbidden material even if asked. The forbidden_surfaces list above protects against input-side leakage (oracle/test/source surfaces). Reducer-level strategy_id enum validation + leakage audit remain Type A controller work."
    },
