                "clarified_statement": {
                  "type": "string",
                  "description": "Materially clearer restatement of the operator's intent; not a typo, punctuation, or headline pass over the voice_anchor."
                },
                "voice_anchor": {
                  "type": "string",
                  "description": "Contiguous 6-20 word substring copied exactly from bounded_raw_seed_excerpt.text; no paraphrase, ellipsis, or stitched phrases."
                },
                "support_excerpt": {"type": "string"},
                "compression_ratio": {"type": "number"},
                "distillation_confidence": {"type": "number"},
                "gestures_towards": {"type": "array"},
                "compression_notes": {"type": "array"}
              }
            }
          },
          "notes": {
            "type": "object"
          },
          "_summary": {
            "type": "object"
          },
          "evidence_refs": {
            "type": "array"
          },
          "omissions": {
            "type": "array"
          },
          "confidence": {
            "type": "number"
          },
          "worker_dissent_or_uncertainty": {
            "type": "string"
          }
        }
