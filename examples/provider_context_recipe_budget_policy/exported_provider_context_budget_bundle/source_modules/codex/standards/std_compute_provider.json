      "validation_command": "./repo-python tools/meta/factory/build_compute_throughput_ledger.py --check",
      "forbidden_surfaces": [
        "source_writes",
        "direct_production_edits",
        "raw_seed_authority_mutation",
        "full_raw_seed_dump"
      ],
      "authority_note": "Type B providers may process bounded raw-seed excerpts into candidate JSON only. The required output is canonical raw-seed distillation shape: shards[].clarified_statement says the operator's intent much more clearly, and shards[].voice_anchor is a verbatim source excerpt. Summary-only takeaway/anchor outputs are invalid. Providers do not author extracted_shards.json, raw_seed.md, doctrine, principles, or final assimilation."
    },
    "check_evidence_pointer": {
      "label": "Affordance-row evidence pointer check",
      "low_authority_allowed": true,
      "required_authority_tier": "provider_endpoint",
      "input_packet": [
        "claim",
        "evidence_ref",
        "bounded_excerpt",
        "output_schema"
      ],
      "output_schema": {
        "type": "object",
        "required": [
          "valid",
          "checked_refs",
          "violations",
          "confidence"
