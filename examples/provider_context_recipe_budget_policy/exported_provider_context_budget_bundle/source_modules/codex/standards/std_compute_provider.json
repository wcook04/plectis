{
  "kind": "standard",
  "schema_version": "std_compute_provider_v1",
  "id": "std_compute_provider",
  "slug": "compute-provider-and-worker-policy",
  "title": "Compute Provider And Worker Policy",
  "status": "active",
  "scope": "repository-wide",
  "purpose": "Contract for auditing model providers, agent harnesses, rate limits, authority tiers, task-class permissions, and schema-gated worker packet routing before cheap or external compute is used.",
  "statement": "Cheap compute consumes materialized holographic projections and returns typed evidence. Context-rich authoring agents own projection authoring, doctrine/shard/skill/paper-module mutation, and final assimilation.",
  "authority_surfaces": {
    "provider_registry": "codex/doctrine/compute/provider_registry.json",
    "generated_ledger": "codex/hologram/compute/ledger.json",
    "generated_model_catalog": "codex/hologram/compute/model_catalog.json",
    "generated_audit": "codex/hologram/compute/audit.json",
    "runtime_module": "system/lib/compute_throughput.py",
    "builder": "tools/meta/factory/build_compute_throughput_ledger.py",
    "bridge_capabilities": "tools/meta/bridge/provider_capabilities.json",
    "provider_pressure": "state/metabolism/metabolism.sqlite::providers",
    "nvidia_status": "system/lib/nvidia_nim.py::runtime_status",
    "openrouter_free_status": "system/lib/openrouter_free_runtime.py::runtime_status"
  },
  "transform_job_standard": "codex/standards/std_transform_job.json",
  "classification_axes": {
    "agency_class": {
      "values": ["operator", "type_a", "type_b", "provider_endpoint", "deterministic_cache"],
      "rule": "Agency class describes what kind of actor is working: controller, bounded worker, raw endpoint, cache, or operator voice."
    },
    "authority_tier": {
      "values": ["operator_voice", "authoring_agent", "bounded_worker", "provider_endpoint"],
      "rule": "Authority tier describes what the actor may author or mutate. A high-intelligence Type B worker remains bounded_worker unless a Type A lane imports and validates its output."
    },
    "intelligence_tier": {
      "values": ["cache", "free_mining", "lower", "middle", "upper", "selectable"],
      "rule": "Intelligence tier describes expected reasoning depth/cost. It is selectable for Bridge ChatGPT model tiers and must not be confused with agency class."
    },
    "bridge_rule": "Bridge is normally agency_class=type_b and authority_tier=bounded_worker. Its intelligence_tier can be lower, middle, or upper depending on selected model/timing tier."
  },
  "provider_model_row_contract": {
    "required_fields": [
      "provider_id",
      "model_id",
      "display_name",
      "endpoint_kind",
      "modalities",
      "capabilities",
      "pricing_class",
      "limit_claims",
      "live_probe_status",
      "latency_stats",
      "schema_score",
      "last_seen_at",
      "source_refs",
      "authority_ceiling"
    ],
    "limit_claim_source_kinds": [
      "unknown",
      "assumed_default",
      "header_observed",
      "operator_override",
      "official_doc"
    ],
    "rule": "Provider model rows are metadata and runtime-status affordance rows. They may guide a transform_job pilot but never authorize broad chat or source mutation by themselves."
  },
  "provider_lane_policy": {
    "rule": "NVIDIA and OpenRouter are separate provider-throughput lanes. The repo hub should maximize both under independent cooldown, quota, and payload gates.",
    "single_job_selection": "A transform_job selects one provider lane for one bounded row transform.",
    "fallback_semantics": "Fallback is same-job recovery after a lane is unavailable; it is not a reason to idle another independent lane.",
    "scheduler_shape": "Always-on provider metabolism materializes tiny per-provider jobs, records receipts and row patches under compute-worker state, and never dispatches broad chat, private payloads, raw-seed rewriting, or source mutation."
  },
  "authority_tiers": {
    "operator_voice": {
      "description": "Human-authored raw intent. Not a worker tier.",
      "can_author": [
        "raw_seed"
      ],
      "low_authority": false
    },
    "authoring_agent": {
      "description": "Context-rich filesystem/navigation envelope with repo rules, validation obligations, and write authority.",
      "can_author": [
        "doctrine",
        "shards",
        "skills",
        "paper_modules",
        "code",
        "final_assimilation"
      ],
      "low_authority": false
    },
    "bounded_worker": {
      "description": "Injected-context worker envelope that consumes materialized projections and returns typed evidence or candidate output under controller validation.",
      "agency_class": "type_b",
      "intelligence_tier": "selectable_by_provider_or_model_tier",
      "can_author": [],
      "low_authority": true
    },
    "provider_endpoint": {
      "description": "Raw model/API backend with no repo semantics. Safe only behind a worker packet and output schema.",
      "can_author": [],
      "low_authority": true
    }
  },
  "limit_claim_sources": [
    "measured",
    "header_observed",
    "official_doc",
    "operator_declared",
    "operator_override",
    "assumed_default",
    "unknown",
    "unverified"
  ],
  "verification_statuses": [
    "local_verified",
    "measured",
    "operator_declared",
    "official_doc",
    "unverified"
  ],
