#!/usr/bin/env bash
# checkpoint — save-button Git for ai_workflow
#
# Usage:
#   ./checkpoint              auto-timestamp message
#   ./checkpoint "my note"    custom message
#   ./checkpoint --dry-run    preview what would be saved
#   ./checkpoint --status     compact pending summary
#   ./checkpoint --force      skip safety warnings; with concurrent live sessions,
#                              broad checkpoints must name dirty paths
#   ./checkpoint --arbiter --unclaimed \
#       --message "bankruptcy: land unclaimed dirty tree state"
#                              stage only dirty paths not covered by active path claims
#   ./checkpoint --arbiter --unclaimed --dry-run
#                              fast path-filter preview; no private-index content staging
#   ./checkpoint --arbiter --unclaimed --dry-run --verify-dry-run-stage
#                              dry-run the full private-index staging path
#   ./checkpoint --rescue-ref --message "rescue: dirty-tree bankruptcy snapshot"
#                              preserve dirt to refs/aiw/rescue/dirty-tree/<run_id>
#   ./checkpoint --backup-status
#                              show private GitHub backup health and uncovered local state
#   ./checkpoint --private-backup --dry-run
#                              plan emergency private preservation
#   ./checkpoint --private-backup --message "backup: private emergency preserve"
#                              checkpoint, preserve old remote tip, and push with lease
#   ./checkpoint --help       show this help
#
# The .gitignore defines what to exclude. This script stages everything
# else, commits, and pushes — one command, no ceremony. Rescue-ref mode is
# the non-pushing internal preservation lane and never updates refs/heads/*.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$REPO_ROOT"

# ── Colors (if terminal) ──
if [[ -t 1 ]]; then
    RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
    CYAN='\033[0;36m'; DIM='\033[2m'; RESET='\033[0m'
else
    RED=''; GREEN=''; YELLOW=''; CYAN=''; DIM=''; RESET=''
fi

# ── Parse args ──
DRY_RUN=false
FORCE=false
RESCUE_REF=false
RESCUE_BRANCH_ALIAS=false
ARBITER=false
UNCLAIMED_ONLY=false
VERIFY_DRY_RUN_STAGE=false
BACKUP_STATUS=false
PRIVATE_BACKUP=false
BACKUP_JSON=false
BACKUP_REMOTE="origin"
BACKUP_BRANCH=""
BACKUP_REF_PREFIX="aiw-backup-origin-main"
MAX_TAIL_DRAINS=2
MSG=""

detect_phase_prefix() {
    local payload
    if [[ ! -x "./repo-python" ]]; then
        return 0
    fi
    payload="$(./repo-python kernel.py --phase 2>/dev/null || true)"
    [[ -z "$payload" ]] && return 0
    python3 -c '
import json, sys
try:
    data = json.load(sys.stdin)
except Exception:
    raise SystemExit(0)
payload = data.get("payload") if isinstance(data, dict) else {}
if not isinstance(payload, dict):
    raise SystemExit(0)
phase = payload.get("phase") if isinstance(payload.get("phase"), dict) else {}
phase_card = payload.get("phase_card") if isinstance(payload.get("phase_card"), dict) else {}
wave = phase_card.get("active_wave") if isinstance(phase_card.get("active_wave"), dict) else {}
phase_number = str(phase.get("phase_number") or phase.get("phase_id") or "").strip()
wave_id = str(wave.get("wave_id") or "").strip()
if phase_number and wave_id:
    print(f"{phase_number}/{wave_id}", end="")
elif phase_number:
    print(phase_number, end="")
' <<< "$payload" 2>/dev/null || true
}

while [[ $# -gt 0 ]]; do
    arg="$1"
    case "$arg" in
        --dry-run)  DRY_RUN=true ;;
        --force)    FORCE=true ;;
        --arbiter)  ARBITER=true ;;
        --unclaimed|--unclaimed-only) UNCLAIMED_ONLY=true ;;
        --verify-dry-run-stage) VERIFY_DRY_RUN_STAGE=true ;;
        --rescue-ref) RESCUE_REF=true ;;
        --backup-status) BACKUP_STATUS=true ;;
        --private-backup|--emergency-private-backup) PRIVATE_BACKUP=true ;;
        --json) BACKUP_JSON=true ;;
        --remote)
            shift
            if [[ $# -eq 0 ]]; then
                echo -e "${RED}ERROR: --remote requires a value.${RESET}"
                exit 1
            fi
            BACKUP_REMOTE="$1"
            ;;
        --branch)
            shift
            if [[ $# -eq 0 ]]; then
                echo -e "${RED}ERROR: --branch requires a value.${RESET}"
                exit 1
            fi
            BACKUP_BRANCH="$1"
            ;;
        --backup-ref-prefix)
            shift
            if [[ $# -eq 0 ]]; then
                echo -e "${RED}ERROR: --backup-ref-prefix requires a value.${RESET}"
                exit 1
            fi
            BACKUP_REF_PREFIX="$1"
            ;;
        --max-tail-drains)
            shift
            if [[ $# -eq 0 ]]; then
                echo -e "${RED}ERROR: --max-tail-drains requires a value.${RESET}"
                exit 1
            fi
            MAX_TAIL_DRAINS="$1"
            ;;
        --rescue-branch)
            RESCUE_REF=true
            RESCUE_BRANCH_ALIAS=true
            ;;
        --message)
            shift
            if [[ $# -eq 0 ]]; then
                echo -e "${RED}ERROR: --message requires a value.${RESET}"
                exit 1
            fi
            MSG="$1"
            ;;
        --status)
            echo -e "${CYAN}Pending changes:${RESET}"
            git status --short | head -60
            TOTAL=$(git status --short | wc -l | tr -d ' ')
            echo -e "${DIM}--- $TOTAL files pending ---${RESET}"
            exit 0
            ;;
        --help|-h)
            echo "checkpoint — save current state to Git + push, or preserve to an internal rescue ref"
            echo ""
            echo "Usage:"
            echo "  ./checkpoint              auto-timestamp message"
            echo "  ./checkpoint \"my note\"    custom message"
            echo "  ./checkpoint --message \"my note\""
            echo "  ./checkpoint --dry-run    preview what would be saved"
            echo "  ./checkpoint --status     compact pending summary"
            echo "  ./checkpoint --force      skip safety warnings; with concurrent live sessions, broad checkpoints must name dirty paths"
            echo "  ./checkpoint --arbiter    allow broad main checkpoint despite active claims/resources"
            echo "  ./checkpoint --arbiter --unclaimed"
            echo "                           checkpoint only dirty paths not covered by active Work Ledger path claims"
            echo "  ./checkpoint --arbiter --unclaimed --dry-run"
            echo "                           fast path-filter preview without private-index content staging"
            echo "  ./checkpoint --arbiter --unclaimed --dry-run --verify-dry-run-stage"
            echo "                           run the full private-index staging path for validation"
            echo "  ./checkpoint --rescue-ref --message \"rescue: dirty-tree bankruptcy snapshot\""
            echo "                           write refs/aiw/rescue/dirty-tree/<run_id>; do not update main; do not push"
            echo "  ./checkpoint --rescue-branch"
            echo "                           alias for --rescue-ref; writes an internal rescue ref, not a checked-out branch and not refs/heads/*"
            echo "  ./checkpoint --backup-status"
            echo "                           show private GitHub backup health, recovery ref state, and uncovered local state"
            echo "  ./checkpoint --private-backup --dry-run"
            echo "                           plan emergency private preservation without writing commits, refs, or remote state"
            echo "  ./checkpoint --private-backup --message \"backup: private emergency preserve\""
            echo "                           verify private remote, checkpoint, preserve old remote tip, force-with-lease if needed, and verify"
            exit 0
            ;;
        -*) echo -e "${RED}Unknown flag: $arg${RESET}"; exit 1 ;;
        *)  MSG="$arg" ;;
    esac
    shift
done

checkpoint_guard_main_landing() {
    if [[ "$DRY_RUN" == "true" ]]; then
        return 0
    fi
    if [[ ! -x "./repo-python" || ! -f "tools/meta/control/mission_transaction_preflight.py" ]]; then
        return 0
    fi
    local summary
    summary="$(./repo-python tools/meta/control/mission_transaction_preflight.py --repo-root "$REPO_ROOT" --landing-bankruptcy-summary 2>/dev/null || true)"
    if [[ -z "$summary" ]]; then
        return 0
    fi
    local decision
    decision="$(python3 -c '
import json, sys
try:
    data = json.load(sys.stdin)
except Exception:
    raise SystemExit(0)
claims = int(data.get("active_claim_count") or 0)
leases = data.get("active_resource_lease_count")
lease_count = -1 if leases is None else int(leases or 0)
effective = int(data.get("effective_active_sessions") or 0)
orphaned = int(data.get("orphaned_session_count") or 0)
print(f"ACTIVE_CLAIMS={claims}")
print(f"ACTIVE_RESOURCE_LEASES={lease_count}")
print(f"EFFECTIVE_ACTIVE_SESSIONS={effective}")
print(f"ORPHANED_SESSIONS={orphaned}")
' <<< "$summary" 2>/dev/null || true)"
    if [[ -z "$decision" ]]; then
        return 0
    fi
    local ACTIVE_CLAIMS=0
    local ACTIVE_RESOURCE_LEASES=-1
    local EFFECTIVE_ACTIVE_SESSIONS=0
    local ORPHANED_SESSIONS=0
    eval "$decision"
    if [[ "$ACTIVE_CLAIMS" -gt 0 || "$ACTIVE_RESOURCE_LEASES" -gt 0 ]]; then
        if [[ "$ARBITER" == "true" ]]; then
            if [[ "$UNCLAIMED_ONLY" == "true" ]]; then
                echo -e "${YELLOW}WARNING: --arbiter --unclaimed is preserving active claimed paths and landing only unclaimed dirty paths.${RESET}"
            else
                echo -e "${YELLOW}WARNING: --arbiter is overriding active claims/resources for a broad checkpoint.${RESET}"
            fi
            echo -e "${DIM}active_claims=${ACTIVE_CLAIMS} active_resource_leases=${ACTIVE_RESOURCE_LEASES}${RESET}"
        else
            echo -e "${RED}ERROR: broad checkpoint to main refused while active claims/resources exist.${RESET}"
            echo -e "${YELLOW}Use ./checkpoint --rescue-ref --message \"rescue: dirty-tree bankruptcy snapshot\" or rerun as --arbiter.${RESET}"
            echo -e "${DIM}active_claims=${ACTIVE_CLAIMS} active_resource_leases=${ACTIVE_RESOURCE_LEASES}${RESET}"
            exit 1
        fi
    fi
    if [[ "$EFFECTIVE_ACTIVE_SESSIONS" -gt 1 ]]; then
        local dirty_paths
        dirty_paths="$(checkpoint_guard_dirty_paths)"
        if [[ -n "$dirty_paths" ]]; then
            if [[ "$UNCLAIMED_ONLY" == "true" ]]; then
                echo -e "${YELLOW}WARNING: multiple live sessions detected; --unclaimed will stage only paths not covered by active path claims.${RESET}"
                echo -e "${DIM}effective_active_sessions=${EFFECTIVE_ACTIVE_SESSIONS}${RESET}"
                return 0
            elif [[ "$FORCE" != "true" ]]; then
                echo -e "${RED}ERROR: broad checkpoint to main refused while multiple live agent sessions exist.${RESET}"
                echo -e "${YELLOW}Use ./checkpoint --rescue-ref --message \"rescue: dirty-tree bankruptcy snapshot\", or rerun with --force and a --message that names every dirty path being swept.${RESET}"
                echo -e "${DIM}effective_active_sessions=${EFFECTIVE_ACTIVE_SESSIONS}${RESET}"
                echo -e "${DIM}dirty_paths:${RESET}"
                checkpoint_guard_print_preview "$dirty_paths"
                exit 1
            fi
            local missing_paths
            missing_paths="$(checkpoint_guard_missing_message_paths "$dirty_paths")"
            if [[ -n "$missing_paths" ]]; then
                echo -e "${RED}ERROR: --force broad checkpoint with live agent sessions must enumerate every dirty path in the commit message.${RESET}"
                echo -e "${YELLOW}Add the missing path(s) to --message, or use rescue-ref instead.${RESET}"
                echo -e "${DIM}missing from message:${RESET}"
                checkpoint_guard_print_preview "$missing_paths"
                exit 1
            fi
            echo -e "${YELLOW}WARNING: --force broad checkpoint is sweeping dirty paths while multiple live agent sessions exist.${RESET}"
            echo -e "${DIM}The commit message enumerates the dirty path manifest.${RESET}"
        fi
    elif [[ "$EFFECTIVE_ACTIVE_SESSIONS" -gt 0 || "$ORPHANED_SESSIONS" -gt 0 ]]; then
        echo -e "${YELLOW}WARNING: effective_active_sessions=${EFFECTIVE_ACTIVE_SESSIONS}; orphaned_sessions=${ORPHANED_SESSIONS}.${RESET}"
        echo -e "${DIM}Continuing because no active claims or measurable resource leases are blocking.${RESET}"
    fi
}

checkpoint_prepare_unclaimed_manifest() {
    local pressure_file="$1"
    local path_file="$2"
    local summary_file="$3"
    local parent_sha="$4"
    if [[ ! -x "./repo-python" || ! -f "tools/meta/factory/work_ledger.py" ]]; then
        echo -e "${RED}ERROR: --unclaimed requires ./repo-python and tools/meta/factory/work_ledger.py.${RESET}"
        exit 1
    fi
    if ! ./repo-python tools/meta/factory/work_ledger.py session-sweep \
        --dry-run \
        --dirty-tree-pressure \
        --bankruptcy-authorized \
        --full \
        --dirty-path-limit 1000000 > "$pressure_file"; then
        echo -e "${RED}ERROR: failed to compute dirty-tree pressure for --unclaimed checkpoint.${RESET}"
        exit 1
    fi
    if ! python3 - "$pressure_file" "$path_file" "$summary_file" "$parent_sha" <<'PY'
import json
import os
import subprocess
import sys
from pathlib import Path

pressure_path = Path(sys.argv[1])
path_file = Path(sys.argv[2])
summary_file = Path(sys.argv[3])
parent_sha = sys.argv[4]
payload = json.loads(pressure_path.read_text(encoding="utf-8"))
card = payload.get("dirty_tree_bankruptcy_pressure", payload)
rows = card.get("dirty_path_rows") if isinstance(card, dict) else []
if not isinstance(rows, list):
    rows = []

def _path_chunks(paths, *, max_count=200, max_bytes=120000):
    chunk = []
    byte_count = 0
    for path in paths:
        path_size = len(path.encode("utf-8", "surrogateescape")) + 1
        if chunk and (len(chunk) >= max_count or byte_count + path_size > max_bytes):
            yield chunk
            chunk = []
            byte_count = 0
        chunk.append(path)
        byte_count += path_size
    if chunk:
        yield chunk

def _git_stdout(args, *, input_data=None, ok_codes=(0,)):
    completed = subprocess.run(
        ["git", *args],
        input=input_data,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if completed.returncode not in ok_codes:
        stderr = completed.stderr.decode("utf-8", "replace").strip()
        raise SystemExit(f"git {' '.join(args)} failed: {stderr or completed.returncode}")
    return completed.stdout

def _decode_nul_paths(raw):
    return {
        item.decode("utf-8", "surrogateescape")
        for item in raw.split(b"\0")
        if item
    }

def _head_tracked_paths(paths):
    tracked = set()
    for chunk in _path_chunks(sorted(set(paths))):
        tracked.update(
            _decode_nul_paths(
                _git_stdout(
                    ["ls-tree", "-r", "-z", "--name-only", parent_sha, "--", *chunk]
                )
            )
        )
    return tracked

def _ignored_paths(paths):
    path_list = sorted(set(paths))
    if not path_list:
        return set()
    payload = b"".join(
        path.encode("utf-8", "surrogateescape") + b"\0" for path in path_list
    )
    return _decode_nul_paths(
        _git_stdout(["check-ignore", "-z", "--stdin"], input_data=payload, ok_codes=(0, 1))
    )

def _path_exists(path):
    candidate = Path(path)
    return candidate.exists() or candidate.is_symlink()

def _path_size(path):
    try:
        return int(os.path.getsize(path))
    except OSError:
        return 0

eligible = []
excluded = []
skipped_ignored = []
skipped_missing_untracked = []
included_classes = {}
seen_includable_classes = {}
candidate_paths = []
for row in rows:
    if not isinstance(row, dict):
        continue
    path = str(row.get("path") or "").strip()
    class_id = str(row.get("class") or "").strip()
    if not path:
        continue
    if class_id == "active_claim_dirty":
        excluded.append(path)
        continue
    if class_id in {"generated_owner_dirty", "unclaimed_source_dirty"}:
        seen_includable_classes[class_id] = (
            seen_includable_classes.get(class_id, 0) + 1
        )
        candidate_paths.append(path)

head_tracked = _head_tracked_paths(candidate_paths)
ignored_untracked = _ignored_paths(
    path for path in candidate_paths if path not in head_tracked
)
missing_untracked = {
    path
    for path in candidate_paths
    if path not in head_tracked and not _path_exists(path)
}
candidate_path_set = set(candidate_paths)
for row in rows:
    if not isinstance(row, dict):
        continue
    path = str(row.get("path") or "").strip()
    class_id = str(row.get("class") or "").strip()
    if path not in candidate_path_set:
        continue
    if path not in head_tracked and path in missing_untracked:
        skipped_missing_untracked.append(path)
        continue
    if path not in head_tracked and path in ignored_untracked:
        skipped_ignored.append(path)
        continue
    eligible.append(path)
    included_classes[class_id] = included_classes.get(class_id, 0) + 1

class_counts = card.get("dirty_path_class_counts") or card.get("class_counts") or {}
expected_seen = sum(
    int(class_counts.get(class_id) or 0)
    for class_id in ("generated_owner_dirty", "unclaimed_source_dirty")
)
if expected_seen and sum(seen_includable_classes.values()) != expected_seen:
    raise SystemExit(
        "dirty-tree pressure manifest was incomplete; refusing unclaimed checkpoint"
    )
expected = (
    sum(seen_includable_classes.values())
    - len(set(skipped_ignored))
    - len(set(skipped_missing_untracked))
)
if expected and len(set(eligible)) != expected:
    raise SystemExit(
        "dirty-tree pressure manifest was incomplete; refusing unclaimed checkpoint"
    )
if not eligible:
    raise SystemExit("no unclaimed dirty paths are available to checkpoint")

eligible_set = set(eligible)
eligible_head_tracked = {path for path in eligible_set if path in head_tracked}
deleted_paths = sorted(path for path in eligible_head_tracked if not _path_exists(path))
modified_paths = sorted(eligible_head_tracked - set(deleted_paths))
added_paths = sorted(eligible_set - head_tracked)
large_added_paths = [
    {"path": path, "size_bytes": _path_size(path)}
    for path in added_paths
    if _path_size(path) > 52428800
]
path_file.write_bytes(
    b"".join(
        path.encode("utf-8", "surrogateescape") + b"\0"
        for path in sorted(eligible_set)
    )
)
summary = {
    "schema": "checkpoint_unclaimed_manifest_v0",
    "included_path_count": len(eligible_set),
    "excluded_active_claim_dirty_path_count": len(set(excluded)),
    "skipped_ignored_untracked_path_count": len(set(skipped_ignored)),
    "skipped_missing_untracked_path_count": len(set(skipped_missing_untracked)),
    "included_dirty_path_classes": included_classes,
    "dry_run_effect_counts": {
        "added": len(added_paths),
        "modified": len(modified_paths),
        "deleted": len(deleted_paths),
        "total": len(eligible_set),
    },
    "large_added_path_count": len(large_added_paths),
    "large_added_paths": large_added_paths[:20],
    "deleted_paths_preview": deleted_paths[:20],
    "deleted_paths_preview_omitted": max(0, len(deleted_paths) - 20),
    "added_paths_preview": added_paths[:20],
    "added_paths_preview_omitted": max(0, len(added_paths) - 20),
    "modified_paths_preview": modified_paths[:20],
    "modified_paths_preview_omitted": max(0, len(modified_paths) - 20),
    "path_filter_validation": {
        "schema": "checkpoint_unclaimed_path_filter_validation_v0",
        "mode": "bulk_git_queries_against_parent_tree",
        "parent": parent_sha,
        "candidate_path_count": len(candidate_path_set),
        "head_tracked_candidate_count": len(head_tracked),
        "ignored_untracked_candidate_count": len(ignored_untracked),
        "missing_untracked_candidate_count": len(missing_untracked),
    },
    "paths_preview": sorted(eligible_set)[:20],
    "paths_preview_omitted": max(0, len(eligible_set) - 20),
    "operator_authorized_unclaimed_checkpoint": card.get(
        "operator_authorized_unclaimed_checkpoint"
    ),
}
summary_file.write_text(
    json.dumps(summary, indent=2, sort_keys=True) + "\n",
    encoding="utf-8",
)
PY
    then
        echo -e "${RED}ERROR: dirty-tree pressure did not produce a safe unclaimed checkpoint manifest.${RESET}"
        exit 1
    fi
}

