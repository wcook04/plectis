{
  "schema_version": "cold_reader_route_map_v1",
  "map_id": "microcosm_public_cold_reader_route_map",
  "cold_reader_goal": "legible_under_10_minutes_without_private_macro_context",
  "routes": [
    {
      "route_id": "tour_project",
      "ordinal": 1,
      "title": "Run the compressed first-screen tour",
      "command": "plectis tour <project>",
      "docs_refs": [
        "README.md#run-it",
        "AGENTS.md#rules"
      ],
      "shows": [
        "first_screen.selected_route_id",
        "front_door_status",
        "route -> work -> event -> evidence",
        ".microcosm state refs",
        "status, observatory, and proof-lab commands"
      ],
      "authority_note": "local first-screen route map only; no provider calls or source mutation"
    },
    {
      "route_id": "status_card",
      "ordinal": 2,
      "title": "Inspect the compressed status lens",
      "command": "plectis status --card <project>",
      "docs_refs": [
        "README.md#run-it",
        "paper_modules/cold_reader_route_map.md"
      ],
      "shows": [
        "front_door.route_selection_proof",
        "front_door.route_explanation",
        "front_door.observatory",
        "front_door.proof_lab",
        "front_door.source_open_body_import_floor"
      ],
      "authority_note": "compressed status lens only; receipts and state files remain drilldown evidence"
    },
    {
      "route_id": "proof_lab",
      "ordinal": 3,
      "title": "Run the bounded proof-lab route",
      "command": "plectis proof-lab --out /tmp/microcosm-proof-lab",
      "docs_refs": [
        "README.md#run-it",
        "AGENTS.md#rules"
      ],
      "shows": [
        "formal_prover_context_strategy_gate",
        "Lean/Lake return code",
        "route component count",
        "proof payload boundary"
      ],
      "authority_note": "bounded public witness only; not general proof correctness authority"
    },
    {
      "route_id": "compile_project",
      "ordinal": 4,
      "title": "Compile a repo into local substrate state",
      "command": "plectis compile <project>",
      "docs_refs": [
        "README.md#run-it",
        "AGENTS.md#rules"
      ],
      "shows": [
        ".microcosm/catalog.json",
        ".microcosm/patterns.json",
        ".microcosm/routes.json",
        ".microcosm/evidence/"
      ],
      "authority_note": "creates local projection state only"
    },
    {
      "route_id": "inspect_route",
      "ordinal": 5,
      "title": "Inspect one route card before opening raw JSON",
      "command": "plectis explain <project> <selected_route_id>",
      "docs_refs": [
        "ARCHITECTURE.md#level-1-the-local-runtime-loop",
        "paper_modules/cold_reader_route_map.md"
      ],
      "shows": [
        "grounded refs",
        "pattern bindings",
        "work transaction contracts",
        "event refs",
        "evidence refs"
      ],
      "authority_note": "explains one public route projection only"
    },
    {
      "route_id": "open_observatory",
      "ordinal": 6,
      "title": "Open the local observatory after route selection",
      "command": "plectis serve <project> --host 127.0.0.1 --port 8765",
      "docs_refs": [
        "ARCHITECTURE.md#level-1-the-local-runtime-loop",
        "paper_modules/public_reveal_walkthrough.md"
      ],
      "shows": [
        "causal chain",
        "route -> work -> event -> evidence",
        "authority ceiling"
      ],
      "authority_note": "serves local read-only observability over project substrate state"
    },
    {
      "route_id": "inspect_public_spine",
      "ordinal": 7,
      "title": "Inspect accepted public runtime organs",
      "command": "plectis spine",
      "docs_refs": [
        "ARCHITECTURE.md#level-3-the-organ-spine-grouped-into-families",
        "AGENTS.md#accepted-public-runtime-spine"
      ],
      "shows": [
        "adapter-backed organs",
        "runtime evidence refs",
        "first-run command path",
        "public-safe authority boundary"
      ],
      "authority_note": "runtime spine projection only; receipts remain drilldown evidence"
    },
    {
      "route_id": "open_import_bridge",
      "ordinal": 8,
      "title": "Open projection intake without private macro context",
      "command": "plectis intake",
      "docs_refs": [
        "README.md#run-it",
        "paper_modules/macro_projection_import_protocol.md"
      ],
      "shows": [
        "macro projection cells",
        "runtime reveal/import bridge",
        "landed readiness-extension status"
      ],
      "authority_note": "public runtime refs only; private source bodies are forbidden"
    },
    {
      "route_id": "open_reveal_board",
      "ordinal": 9,
      "title": "Open the ten-minute public reveal board",
      "command": "plectis reveal",
      "docs_refs": [
        "README.md#run-it",
        "paper_modules/public_reveal_walkthrough.md"
      ],
      "shows": [
        "ten-minute reveal board",
        "negative cases",
        "evidence ref count",
        "release_authorized=false"
      ],
      "authority_note": "public reveal walkthrough only; release remains unauthorized"
    },
    {
      "route_id": "inspect_cold_reader_route_map",
      "ordinal": 10,
      "title": "Validate the route map itself",
      "command": "plectis cold-reader-route-map run-route-map-bundle",
      "docs_refs": [
        "README.md#run-it",
        "paper_modules/cold_reader_route_map.md"
      ],
      "shows": [
        "first-run route sequence",
        "command refs",
        "receipt-backed route cards",
        "authority ceiling"
      ],
      "authority_note": "route-map projection only; not route registry authority"
    }
  ],
  "release_authorized": false,
  "private_source_bodies_exported": false,
  "body_in_receipt": false
}
